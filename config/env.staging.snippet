# 测试服 .env 片段（merge 到 /opt/vidau-workflow/.env）
# 对应 Git 分支 test · 主站/SSO 测试环境 *.vidau.info
# 勿提交真实密钥；密钥从 SSO 管理后台 / @彭悠 申请

AUTH_ENABLED=true
AUTH_MODE=platform
AUTH_COOKIE_SECURE=true
AUTH_FLOW_SESSION_ONLY=true
SECRET_KEY=请替换为随机长字符串

PUBLIC_BASE_URL=https://adflow.vidau.info
APP_DOMAIN=adflow.vidau.info

# --- SSO（测试）---
# SSO_ENV 留空，按 APP_DOMAIN 自动识别（*.vidau.info → development → sso.vidau.info）
SSO_ENV=
# 测试 SSO 应用（管理后台 Ad Flow Agent Test · /ad-flow-agent-test）
SSO_APP_ID=ad-flow-agent-test
# 可选：强制指定 SSO 根地址（默认 https://sso.vidau.info）
# SSO_BASE_URL=https://sso.vidau.info

# --- 主站 API（测试）---
PLATFORM_API_URL=https://app-api.vidau.info/api

# --- 积分 / 出片 ---
# 测试阶段先关闭主站扣币，便于跑通 UI 与生成流程（仍走 platform 出片，但不 deduct）
AIGC_BILLING_MODE=none
# 恢复扣费测试时改回：AIGC_BILLING_MODE=platform
AGENT_COIN_API_KEY=向彭悠申请测试环境 sk-agent-...
VIDEO_PROVIDER=platform
AGENT_CODE=vidau_flow

WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8787

# --- AdFlow 首页快速生成 ---
TOC_DEFAULT_LANGUAGE=英语
TOC_METRICS_ENABLED=true

# --- TikTok UGC 出片（15s 单段 · Seedance 原生有声 · 画面无烧录字幕）---
VIDEO_DEFAULT_DURATION_SEC=15
VIDEO_SEGMENT_STRATEGY=single
SEEDANCE_UGC_STYLE=true
TTS_MUTE_SEEDANCE_AUDIO=false
TTS_POST_ENABLED=false
TTS_FIT_TO_VIDEO_SEC=15
# 参考视频/产品图公网前缀（Seedance reference_video 须 HTTP URL；留空则仅用产品图）
# SEEDANCE_ASSET_PUBLIC_BASE_URL=https://adflow.vidau.info/uploads

# --- LLM：Vertex Gemini ---
# 凭据随 Git 部署：config/gemini-vertex-sa.json
# 项目/区域见 config/env.vertex.snippet；pull 后执行：
#   bash scripts/apply_test_gemini_vertex.sh
# 可选 fallback：服务器 .env 中 NUWA_API_KEY=...
