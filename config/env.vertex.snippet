# Vertex Gemini（测试服默认；随 Git 部署，.env 同名变量可覆盖）
# 认证：config/gemini-vertex-sa.json（随仓库部署到测试服）

LLM_PROVIDER=gemini
LLM_FALLBACK_PROVIDER=nuwa
GEMINI_USE_VERTEX=true
GEMINI_VERTEX_PROJECT=project-gemini-0506
GEMINI_VERTEX_LOCATION=us-central1
GEMINI_VERTEX_CREDENTIALS=config/gemini-vertex-sa.json
GEMINI_TEXT_MODEL=gemini-2.0-flash
