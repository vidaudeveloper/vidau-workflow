# LLM 提供商：gemini | nuwa | openai
# 默认加载 config/env.vertex.snippet（Vertex 项目/区域，随 Git 部署）
# 本地密钥：config/internal.env（不入库）或根目录 .env
LLM_PROVIDER=gemini
LLM_FALLBACK_PROVIDER=nuwa

# Gemini — Vertex（推荐）或 AI Studio
# 测试服：config/gemini-vertex-sa.json 随 Git 部署
GEMINI_USE_VERTEX=false
GEMINI_VERTEX_PROJECT=
GEMINI_VERTEX_LOCATION=us-central1
GEMINI_VERTEX_CREDENTIALS=config/gemini-vertex-sa.json
GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_TEXT_MODEL=gemini-2.0-flash

# OpenAI（备用）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Nuwa（LLM / 视觉识别备用）
NUWA_API_KEY=
NUWA_API_BASE=https://api.nuwaapi.com/v1
NUWA_MODEL=gpt-4o-mini
NUWA_VISION_MODEL=gpt-4.1

# LLM 吞吐：并行条数（默认 3）；请求间隔秒（默认 0，限流时可设 1–2）
LLM_MAX_CONCURRENCY=3
LLM_REQUEST_INTERVAL_SEC=0

# 视频提供商：seedance（火山方舟直连）| platform（主站 aiVideo 扣积分）| openai
VIDEO_PROVIDER=seedance

# 主站 AI Video（VIDEO_PROVIDER=platform 或 AIGC_BILLING_MODE=platform 时）
PLATFORM_VIDEO_MODEL=happyhorse_1.0
PLATFORM_VIDEO_RESOLUTION=1080p
PLATFORM_VIDEO_POLL_INTERVAL_SEC=5

# Seedance 2.0 — 火山方舟（szxx 项目 endpoint）
SEEDANCE_API_KEY=
SEEDANCE_API_BASE=https://ark.cn-beijing.volces.com
SEEDANCE_MODEL=ep-20260513151304-mtzpn
SEEDANCE_MODEL_FAST=ep-20260513151335-tc8qj
SEEDANCE_USE_FAST=false
# Seedance 轮询间隔（秒），越小越快感知完成，默认 3
SEEDANCE_POLL_INTERVAL_SEC=3

# OpenAI 视频（备用）
VIDEO_API_KEY=
VIDEO_API_BASE=https://api.openai.com/v1
VIDEO_MODEL=sora

WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8787

# 对外域名（Nginx 反代 + HTTPS 后同事用此地址）
PUBLIC_BASE_URL=https://adflow.vidau.ai
APP_DOMAIN=adflow.vidau.ai

# 数据库（SQLite 文件路径，相对项目根目录）
DATABASE_PATH=data/workflow.db
# 设置后切换到 PostgreSQL（留空则用上面的 SQLite）。本地可用 docker-compose 起 PG：
#   docker compose up -d postgres
#   迁移现有数据：python scripts/migrate_sqlite_to_pg.py
DATABASE_URL=
# 示例：DATABASE_URL=postgresql://vidau:vidau@localhost:5433/vidau_flow

# 登录鉴权（生产环境建议开启）
AUTH_ENABLED=false
SECRET_KEY=请替换为随机长字符串
AUTH_COOKIE_SECURE=false
# 首次开启鉴权时用于自动创建管理员（创建后可改密码并清空此项）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=请设置强密码
ADMIN_DISPLAY_NAME=管理员

# === VidAU 主站对接（账号 / 积分 / SSO）===
# 测试 vs 正式对照表 + Next.js 变量映射：config/sso_env.md
# 测试模板：config/env.staging.snippet  正式模板：config/env.production.snippet
#
# 鉴权模式：local（本地密码登录）| platform（主站 Token + SSO）
AUTH_MODE=local
# 主站 API 根（须带 /api 后缀）
#   测试：https://app-api.vidau.info/api
#   正式：https://app-api.vidau.ai/api
PLATFORM_API_URL=https://app-api.vidau.info/api
# 服务端 S2S 鉴权头 X-Service-Auth（如主站要求），留空不发送
SERVICE_AUTH_SECRET=
# token→userId 内存缓存 TTL（毫秒）
AUTH_USER_CACHE_TTL_MS=60000
# 开发兜底：主站不可达时从 JWT 解析 userId（仅本地冒烟，生产置 false）
AUTH_DEV_FALLBACK=false
# 主站登录 Cookie 名（同域共享）/ 开发 token Cookie 名
PLATFORM_TOKEN_COOKIE=VidAu-Token
PLATFORM_DEV_TOKEN_COOKIE=VidAu-Agent-Dev-Token
# VidAU SSO（auth_mode=platform 时必填）
# 测试：ad-flow-agent-test（Ad Flow Agent Test）
# 正式：ad-flow-agent（Ad Flow Agent）
SSO_APP_ID=ad-flow-agent
# SSO 环境：production | development | 留空则按 APP_DOMAIN 自动（.vidau.info→测试，.vidau.ai→正式）
SSO_ENV=
# 可选：覆盖 SSO 根地址（默认按 SSO_ENV 选择 .ai / .info）
SSO_BASE_URL=
# 出片计费：none（不扣）| platform（Agent 扣币/退币 + 主站出片）
AIGC_BILLING_MODE=none
# Agent 扣退币 inner API 的 api-key（生产向主站 / @彭悠 申请）
AGENT_COIN_API_KEY=
# Agent 套餐购买页（?agent_code= 仅展示本 Agent 卡片）
AGENT_CODE=vidau_flow
AGENT_PURCHASE_BASE_URL=https://www.vidau.ai/agent-price
# true=须在本站 SSO 登录后才算已登录（推荐 Agent 独立站）
AUTH_FLOW_SESSION_ONLY=true
# 接主站出片示例：VIDEO_PROVIDER=platform、AIGC_BILLING_MODE=platform、AUTH_MODE=platform

# --- AdFlow 首页快速生成 ---
TOC_DEFAULT_LANGUAGE=英语
TOC_METRICS_ENABLED=true

# 字幕口播对齐（faster-whisper，本地 CPU 可跑 base.en）
SUBTITLE_ALIGN_ENABLED=true
SUBTITLE_WHISPER_MODEL=base.en
SUBTITLE_WHISPER_DEVICE=cpu
SUBTITLE_WHISPER_COMPUTE_TYPE=int8
# 首次运行 python scripts/download_whisper_model.py（走 ModelScope，国内可用）
SUBTITLE_WHISPER_MODEL=data/models/whisper/ms/Systran/faster-whisper-base___en
SUBTITLE_WHISPER_HF_ENDPOINT=https://hf-mirror.com
SUBTITLE_WHISPER_DOWNLOAD_ROOT=data/models/whisper
SUBTITLE_ALIGN_PROVIDER=auto

# TTS 后期口播（推荐：Edge TTS 替换 Seedance 音轨，字幕按 TTS 时间戳烧录）
TTS_POST_ENABLED=false
TTS_PROVIDER=edge
TTS_VOICE=  # 留空则按账号人设自动分配；填写则全站锁定同一 Edge TTS 音色
TTS_MUTE_SEEDANCE_AUDIO=false
TTS_RATE=+0%
TTS_SEGMENT_GAP_SEC=0.2
TTS_PAUSE_GAP_SEC=0.2
TTS_FIT_TO_VIDEO_SEC=15
TTS_EXTEND_VIDEO=true
TTS_MAX_SPEEDUP=1.1

# 默认成片规格（无 Workflow Blueprint 时）
VIDEO_DEFAULT_DURATION_SEC=15
VIDEO_SEGMENT_STRATEGY=single
SEEDANCE_UGC_STYLE=true
# 参考素材公网 URL 前缀（本地 data URL 不可用）
SEEDANCE_ASSET_PUBLIC_BASE_URL=
